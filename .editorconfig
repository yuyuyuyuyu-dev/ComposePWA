root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
# Compose @Composable functions conventionally use PascalCase.
ktlint_function_naming_ignore_when_annotated_with = Composable

[*.{js,css,html,json,jsonc,yml,yaml,md,toml}]
indent_size = 2

# Markdown allows trailing spaces for hard line breaks.
[*.md]
trim_trailing_whitespace = false

[*.{bat,cmd}]
end_of_line = crlf
