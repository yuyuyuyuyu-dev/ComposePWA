{
  "name": "composepwa-tooling",
  "version": "0.0.0",
  "private": true,
  "description": "Formatter & linter tooling for the ComposePWA repository (web assets).",
  "license": "Apache-2.0",
  "scripts": {
    "format": "prettier --write . && taplo fmt",
    "format:check": "prettier --check . && taplo fmt --check",
    "lint:eslint": "eslint .",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:html": "htmlhint \"**/*.html\" --ignore \"**/build/**,**/node_modules/**,example/**,tmp/**\"",
    "lint:md": "markdownlint-cli2",
    "lint:toml": "taplo lint",
    "lint:actions": "actionlint",
    "lint": "npm run format:check && npm run lint:eslint && npm run lint:css && npm run lint:html && npm run lint:md && npm run lint:toml",
    "fix": "npm run format && eslint . --fix && stylelint \"**/*.css\" --fix && markdownlint-cli2 --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@taplo/cli": "^0.7.0",
    "eslint": "^10.5.0",
    "eslint-plugin-yml": "^3.4.0",
    "globals": "^17.6.0",
    "htmlhint": "^1.9.2",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
