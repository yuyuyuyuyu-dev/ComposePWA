{
  "config": {
    "default": true,
    // Line length is governed by Prettier (prose is wrapped manually).
    "MD013": false,
    // Inline HTML is required for README badges and images.
    "MD033": false
  },
  "globs": ["**/*.md"],
  "ignores": [
    "**/node_modules/**",
    "**/build/**",
    ".gradle/**",
    ".idea/**",
    ".kotlin/**",
    "example/**",
    "tmp/**"
  ]
}
